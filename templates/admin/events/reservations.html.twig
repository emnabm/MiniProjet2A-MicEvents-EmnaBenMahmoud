<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Réservations — {{ event.title }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">
    <div class="card p-4">
        <div class="d-flex justify-content-between mb-3">
            <h2>Réservations : {{ event.title }}</h2>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">← Retour</a>
        </div>

        <p class="text-muted">{{ event.reservations|length }} réservation(s) / {{ event.seats }} places</p>

        {% if event.reservations is empty %}
            <div class="alert alert-info">Aucune réservation pour cet événement.</div>
        {% else %}
            <table class="table table-striped">
                <thead>
                    <tr><th>#</th><th>Nom</th><th>Email</th><th>Téléphone</th><th>Date réservation</th></tr>
                </thead>
                <tbody>
                    {% for i, reservation in event.reservations %}
                    <tr>
                        <td>{{ i+1 }}</td>
                        <td>{{ reservation.name }}</td>
                        <td>{{ reservation.email }}</td>
                        <td>{{ reservation.phone }}</td>
                        <td>{{ reservation.createdAt|date('d/m/Y H:i') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
</body>
</html>