{% extends 'base.html.twig' %}
{% block title %}Reserve — {{ event.title }}{% endblock %}

{% block stylesheets %}
<style>
    body {  background-size: cover; background-position: center; }
    body::before { content:''; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:0; }
    main { position:relative; z-index:1; }
    .screen {
        display: flex; flex-direction: column; align-items: center; gap: 15px;
        width: 90%; max-width: 450px; margin: 3rem auto;
        padding: 30px; border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(0,49,97,0.3);
    }
    .screen input {
        padding: 14px 16px; width: 100%;
        border: none; border-radius: 10px;
        background: rgba(255,255,255,0.2); color: white; font-size: 15px;
        font-family: inherit;
        transition: all 0.3s;
    }
    .screen input::placeholder { color: rgba(255,255,255,0.6); }
    .screen input:focus { outline: none; background: rgba(255,255,255,0.3); box-shadow: 0 0 12px rgba(255,255,255,0.2); }
    .screen button {
        padding: 14px 40px; width: 100%;
        border: none; border-radius: 28px;
        background: #C7953E; color: #003161;
        font-size: 16px; font-weight: 700; cursor: pointer;
        letter-spacing: 1px; text-transform: uppercase;
        font-family: inherit; transition: all 0.3s;
    }
    .screen button:hover { transform: scale(1.03); box-shadow: 0 0 15px rgba(199,149,62,0.5); }
</style>
{% endblock %}

{% block body %}
<main>
    <div class="screen">
        <i class="fas fa-ticket-alt" style="font-size:2.5rem; color:#C7953E;"></i>
        <h2 style="color:white; text-align:center;">Reserve Your Spot</h2>

        <div style="background:rgba(255,255,255,0.1); padding:1rem; border-radius:10px; width:100%; text-align:center;">
            <h3 style="color:#C7953E; margin:0;">{{ event.title }}</h3>
            <p style="color:rgba(255,255,255,0.8); margin:0.5rem 0 0;">
                {{ event.date|date('F d, Y H:i') }} — {{ event.location }}
            </p>
        </div>

        {% if success %}
            <div class="alert alert-success" style="width:100%; border-radius:10px;">
                
                <strong>Reservation confirmed!</strong><br>
                Your spot for <strong>{{ event.title }}</strong> is reserved.
            </div>
            <a href="{{ path('events_list') }}" class="btn btn-secondary" style="width:100%; justify-content:center;">
                 Browse More Events
            </a>
        {% else %}
            {% if error %}
                <div class="alert alert-danger" style="width:100%; border-radius:10px;">
                     {{ error }}
                </div>
            {% endif %}

            <form method="POST" style="width:100%; display:flex; flex-direction:column; gap:12px;">
                <input type="text" name="name" placeholder="Full Name"
                       value="{{ app.user ? app.user.username : '' }}" required>
                <input type="email" name="email" placeholder="Email"
                       value="{{ app.user ? app.user.getUserIdentifier() : '' }}" required>
                <input type="tel" name="phone" placeholder="Phone (+216 XX XXX XXX)" required>
                <button type="submit">
                     Confirm Reservation
                </button>
            </form>

            <a href="{{ path('event_detail', {id: event.id}) }}"
               style="color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.9rem;">
                 Back to event
            </a>
        {% endif %}
    </div>
</main>
{% endblock %}